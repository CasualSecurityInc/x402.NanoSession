# NanoSession Workspace Configuration (Mainnet)
# Copy this file to mainnet.env and fill in your values
# DO NOT commit mainnet.env to git

# ---------------------------------------------------------------------
# 1. Nano WebSockets (For the Demo Server Facilitator)
# ---------------------------------------------------------------------
# The WebSocket URL to listen for confirmed Nano payments
# Default: wss://ws.nano.to
NANO_WS_URL=wss://ws.nano.to

# The server address that the Facilitator watches for incoming dust payments
# This address MUST be monitored by the WebSocket URL specified above.
# (P.S. If you leave this as the default x402.NanoSession project address, 
# any "dust" you send along during testing is considered a tiny, much-appreciated donation! ☕️)
NANO_SERVER_ADDRESS=nano_1x4ns13z4a57bm8y11b6y4rrg8mo54ip5o3edso7y9j7hpjfcgjbkkimtemc

# ---------------------------------------------------------------------
# 2. Nano RPC (For the integration tests and the Demo Server)
# ---------------------------------------------------------------------
# Nano RPC endpoint URL
# Default: https://rpc.nano-gpt.com or https://rpc.nano.to
# 
# URL query parameters are extracted and merged into each RPC request body.
# This allows passing API keys or other provider-specific parameters:
#   NANO_RPC_URL=https://rpc.nano.to?key=YOUR-API-KEY
NANO_RPC_URL=https://rpc.nano-gpt.com

# ---------------------------------------------------------------------
# Integration Tests & Playwright Scripts
# ---------------------------------------------------------------------
# Test wallet seed (64 character hex string)
# Account #0: Client account (source of test payments)
# Account #1: Server account (receives payments)
NANO_SEED=your_64_char_hex_seed_here

# Maximum spend per automated test run (in raw)
# 0.001 XNO = 1000000000000000000000000000 raw
# Keep this small to avoid accidental large spends on Mainnet
NANO_MAX_SPEND=1000000000000000000000000000

# ---------------------------------------------------------------------
# 4. Local App Server URLs
# ---------------------------------------------------------------------
# Generic URL consumed by the backend server and integration tests
VITE_TEST_AND_DEMO_SERVER_URL=http://localhost:3001

# Frontend Configuration URLs (Consumed by VitePress)
VITE_MAINNET_DEMO_URL=http://localhost:3001
VITE_TESTNET_DEMO_URL=http://localhost:3002
VITE_ENABLE_TESTNET_TAB=false
