{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
 "paths": {
      "@nanosession/core": [
        "./packages/core/src/index.ts"
      ],
      "@nanosession/client": [
        "./packages/client/src/index.ts"
      ],
      "@nanosession/facilitator": [
        "./packages/facilitator/src/index.ts"
      ],
      "@nanosession/rpc": [
        "./packages/rpc/src/index.ts"
      ],
      "@nanosession/faremeter": [
        "./packages/faremeter-plugin/src/index.ts"
      ],
      "@nanosession/x402": [
        "./packages/x402-adapter/src/index.ts"
      ],
      "@nanosession/x402/server": [
        "./packages/x402-adapter/src/server.ts"
      ],
      "@nanosession/x402/facilitator": [
        "./packages/x402-adapter/src/facilitator.ts"
      ],
      "@nanosession/x402/client": [
        "./packages/x402-adapter/src/client.ts"
      ]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "packages/*/src/**/*.test.ts",
    "examples"
  ],
  "references": [
    {
      "path": "./packages/core"
    },
    {
      "path": "./packages/rpc"
    },
    {
      "path": "./packages/client"
    },
    {
      "path": "./packages/facilitator"
    },
    {
      "path": "./packages/faremeter-plugin"
    },
    {
      "path": "./packages/x402-adapter"
    }
  ]
}